# Copy this file to ".env" and fill in real values.
# These are loaded automatically at startup (via spring-dotenv) and map to application.yml.

# MongoDB connection string (MongoDB Atlas)
DATABASE_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/splitpay?retryWrites=true&w=majority&appName=<AppName>

# HMAC secret used to sign JWTs. MUST be at least 32 characters (256 bits) for HS256.
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Google Gemini API key (used to parse OCR'd bill text into structured items)
GEMINI_API_KEY=your-gemini-api-key

# HTTP port (defaults to 4000, same as the old Node app)
PORT=4000

# Optional: directory containing <lang>.traineddata for Tesseract OCR.
# Defaults to "." (the backend folder), where eng.traineddata already lives.
# TESSDATA_PREFIX=.
